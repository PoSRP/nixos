#!/usr/bin/env bash

set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: $0 /dev/sdX"
    echo ""
    echo "Flash the NixOS installer ISO to a USB drive."
    echo ""
    echo "Build the ISO first with: scripts/build-iso"
    echo "After booting the USB, run:"
    echo "  sudo /iso/config/scripts/install"
    exit 0
fi

DEVICE="${1:-}"

if [[ -z "$DEVICE" ]]; then
    echo "Usage: $0 /dev/sdX"
    exit 1
fi

if [[ ! -b "$DEVICE" ]]; then
    echo "Error: $DEVICE is not a block device"
    exit 1
fi

if grep -q "^$DEVICE" /proc/mounts 2>/dev/null; then
    echo "Error: $DEVICE (or a partition on it) is currently mounted"
    exit 1
fi

REPO_ROOT="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"
ISO=$(ls "$REPO_ROOT/result-iso/iso/"*.iso 2>/dev/null | head -1)

if [[ -z "$ISO" ]]; then
    echo "Error: no ISO found at result-iso/iso/. Run scripts/build-iso first."
    exit 1
fi

echo "  ISO : $ISO"
echo "  USB : $DEVICE"
echo ""
echo "WARNING: everything on $DEVICE will be permanently erased."
read -rp "Type YES to continue: " confirm

if [[ "$confirm" != "YES" ]]; then
    echo "Aborted."
    exit 1
fi

echo "Flashing..."
sudo dd if="$ISO" of="$DEVICE" bs=4M status=progress oflag=sync
echo "Done. You can now boot from $DEVICE."
